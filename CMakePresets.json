{
  "version": 6,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "QE6502_BUILD_TESTS": "ON",
        "QE6502_BUILD_WASM": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "QE6502_BUILD_TESTS": "ON",
        "QE6502_BUILD_WASM": "OFF"
      }
    },
    {
      "name": "wasm",
      "displayName": "WebAssembly",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/wasm",
      "toolchainFile": "${sourceDir}/cmake/toolchains/wasm32-unknown-unknown-clang.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "QE6502_BUILD_WASM": "ON",
        "QE6502_BUILD_TESTS": "OFF",
        "QE6502_BUILD_SHARED": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "wasm",
      "configurePreset": "wasm"
    }
  ]
}
